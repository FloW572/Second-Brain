# ---- Telegram ----
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to use the bot.
# Leave empty = allow everyone (NOT recommended). Get your ID via @userinfobot.
ALLOWED_TELEGRAM_USER_IDS=

# ---- Anthropic ----
ANTHROPIC_API_KEY=

# ---- Database ----
# For local (non-docker) runs use localhost. docker-compose overrides the host to "db".
DATABASE_URL=postgresql://secondbrain:secondbrain@localhost:5432/secondbrain
POSTGRES_PASSWORD=secondbrain

# ---- Models ----
EMBEDDING_MODEL=BAAI/bge-m3
ROUTER_MODEL=claude-haiku-4-5-20251001
EXTRACT_MODEL=claude-haiku-4-5-20251001
QUERY_MODEL=claude-opus-4-8

# ---- Speech-to-text (lokal, faster-whisper) ----
# Modellgröße: tiny | base | small | medium | large-v3 (größer = besser, aber langsamer)
WHISPER_MODEL=small
# Sprache als ISO-Code (z.B. de, en) oder "auto" zum Erkennen
WHISPER_LANGUAGE=de

# ---- Locale ----
TIMEZONE=Europe/Vienna

# ---- Proaktive Briefings (Digest & Review) ----
# Explizite Schalter für die automatischen (geplanten) Briefings.
# false = keine automatischen Nachrichten; die Befehle /digest und /review
# funktionieren weiterhin manuell.
DIGEST_ENABLED=false
REVIEW_ENABLED=false

# ---- Täglicher Digest ----
# Lokale Stunde im 24-Stunden-Format (0-23) für die Morgen-Zusammenfassung.
# An/Aus über DIGEST_ENABLED (oben), nicht über diesen Wert.
DIGEST_HOUR=8

# ---- Wöchentliches Review ----
# Wochentag (0=Mo .. 6=So) + lokale Stunde im 24-Stunden-Format (0-23).
# An/Aus über REVIEW_ENABLED (oben), nicht über diese Werte.
REVIEW_WEEKDAY=6
REVIEW_HOUR=18

# ---- Beobachtbarkeit (Kosten/Nutzung) ----
# Pro Anthropic-Aufruf werden Tokens, Latenz und geschätzte Kosten geloggt; /stats
# zeigt die laufende Summe seit Start. Ist der Wert > 0, wird EINMALIG eine Warnung
# ins Log geschrieben, sobald die geschätzten Ausgaben seit Start diese USD-Grenze
# überschreiten (0 = keine Warnung). Keine harte Sperre.
COST_WARN_THRESHOLD_USD=0
