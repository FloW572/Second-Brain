# ---- Telegram ----
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to use the bot.
# Leave empty = allow everyone (NOT recommended). Get your ID via @userinfobot.
ALLOWED_TELEGRAM_USER_IDS=

# ---- Anthropic ----
ANTHROPIC_API_KEY=

# ---- Database ----
# For local (non-docker) runs use localhost. docker-compose overrides the host to "db".
DATABASE_URL=postgresql://secondbrain:secondbrain@localhost:5432/secondbrain
POSTGRES_PASSWORD=secondbrain

# ---- Models ----
EMBEDDING_MODEL=BAAI/bge-m3
ROUTER_MODEL=claude-haiku-4-5-20251001
EXTRACT_MODEL=claude-haiku-4-5-20251001
QUERY_MODEL=claude-opus-4-8

# ---- Locale ----
TIMEZONE=Europe/Vienna
